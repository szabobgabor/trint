{% extends 'base.html.twig' %}

{% block title %}Hello CompaniesController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    This friendly message is coming from:
    <ul>
        <li>Your controller at <code>/app/src/Controller/CompaniesController.php</code></li>
        <li>Your template at <code>/app/templates/companies/index.html.twig</code></li>
    </ul>

    <ul>
        {% for stat in companyStats %}
            <li>
                <span>{{ stat.companyName }}</span>
                <span>{{ stat.averageRating }}</span>
                <span>{{ stat.numberOfReviews }}</span>
            </li>
        {% endfor %}
    </ul>


</div>
{% endblock %}
