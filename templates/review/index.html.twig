{% extends 'base.html.twig' %}

{% block title %}Hello ReviewController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    This friendly message is coming from:
    <ul>
        <li>Your controller at <code>/app/src/Controller/ReviewController.php</code></li>
        <li>Your template at <code>/app/templates/review/index.html.twig</code></li>
    </ul>
    {{ form(review_form) }}
    <div>
        {% for review in reviews %}
            <div>
                {# @var review \App\Entity\Review #}
                <span>{{ review.getCompany().getName() }}</span>
                <span>{{ review.getRating() }}</span>
                <span>{{ review.getReviewText() }}</span>
                <span>{{ review.getCreatedAt().format('Y.m.d. H:i:s') }}</span>
            </div>
        {% endfor %}
    </div>
    {% if (cursor) %}
        <a href="{{ path('app_reviews') }}">legfrissebb</a>
    {% endif %}

    {% if (lastId) %}
        <a href="{{ path('app_reviews', {cursor: lastId}) }}">több elem</a>
    {% endif %}
</div>
{% endblock %}
