{% extends 'base.html.twig' %}

{% block title %}Hello ReviewController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <div>
            {# @var review \App\Entity\Review #}
            <span>{{ review.getCompany().getName() }}</span>
            <span>{{ review.getRating() }}</span>
            <span>{{ review.getReviewText() }}</span>
            <span>{{ review.getCreatedAt().format('Y.m.d. H:i:s') }}</span>
        </div>
    </div>
{% endblock %}
